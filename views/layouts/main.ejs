<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %> — SugarWatch</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" >
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body>

<div class="app-wrapper">

  <!-- Sidebar -->
  <div id="sidebarOverlay" class="sidebar-overlay" onclick="toggleSidebar()"></div>
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-logo">
      <a href="/dashboard" class="brand">Sugar<span>Watch</span></a>
      <div class="tagline">India's Sugar Tracker</div>
    </div>

    <nav class="sidebar-nav">
      <div class="nav-section-label">Main</div>
      <a href="/dashboard" class="nav-link <%= typeof title !== 'undefined' && title === 'Dashboard' ? 'active' : '' %>">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        Dashboard
      </a>
      <a href="/scan" class="nav-link <%= typeof title !== 'undefined' && title === 'Scan Product' ? 'active' : '' %>">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="6" height="18"/><rect x="10" y="3" width="2" height="18"/><rect x="14" y="3" width="4" height="18"/><rect x="20" y="3" width="1" height="18"/></svg>
        Scan Barcode
      </a>
      <a href="/products" class="nav-link <%= typeof title !== 'undefined' && title === 'Product Database' ? 'active' : '' %>">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
        Products
      </a>

      <div class="nav-section-label" style="margin-top:.5rem;">Account</div>
      <a href="/profile" class="nav-link <%= typeof title !== 'undefined' && title === 'My Profile' ? 'active' : '' %>">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
        My Profile
      </a>
      <a href="/profile/history" class="nav-link <%= typeof title !== 'undefined' && title === 'Food History' ? 'active' : '' %>">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 6v6l4 2"/></svg>
        Food History
      </a>
      <a href="/about" class="nav-link <%= typeof title !== 'undefined' && title === 'About' ? 'active' : '' %>">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 6v6l4 2"/></svg>
        About This site
      </a>
      <a href="/auth/logout" class="nav-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16,17 21,12 16,7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Sign Out
      </a>
    </nav>

    <div class="sidebar-footer">
      <a href="/profile" class="user-pill" style="text-decoration:none;">
        <div class="user-avatar"><%= user ? user.name.split(' ').map(n=>n[0]).join('').toUpperCase().slice(0,2) : 'SW' %></div>
        <div>
          <div class="user-pill-name"><%= user ? user.name.split(' ')[0] : 'User' %></div>
          <div class="user-pill-role"><%= user ? user.email : '' %></div>
        </div>
      </a>
    </div>
  </aside>

  <!-- Overlay -->
  <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

  <!-- Main Content -->
  <main class="main-content">
    <div class="topbar">
      <div class="topbar-left" style="display:flex;align-items:center;gap:12px;">
        <button class="sidebar-toggle" onclick="toggleSidebar()" aria-label="Menu">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
        <div>
          <h1><%= title %></h1>
          <p><%= new Date().toLocaleDateString('en-IN', { weekday:'long', day:'numeric', month:'long', year:'numeric' }) %></p>
        </div>
      </div>
      <div class="topbar-right">
        <a href="/scan" class="btn btn-primary btn-sm">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="6" height="18"/><rect x="10" y="3" width="2" height="18"/><rect x="14" y="3" width="4" height="18"/></svg>
          Scan
        </a>
      </div>
    </div>

    <div class="page-body">
      <% if (success && success.length > 0) { %>
        <div class="alert alert-success">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22,4 12,14.01 9,11.01"/></svg>
          <%= success[0] %>
        </div>
      <% } %>
      <% if (error && error.length > 0) { %>
        <div class="alert alert-error">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
          <%= error[0] %>
        </div>
      <% } %>

      <%- body %>
    </div>
  </main>
</div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>

<script src="/js/app.js"></script>
</body>
</html>
