<script>
// 1. Initialize the library
const html5QrCode = new Html5Qrcode("interactive");

// 2. Define what happens when a barcode is found
const qrCodeSuccessCallback = (decodedText) => {
    console.log("Barcode Found: " + decodedText);
    html5QrCode.stop().then(() => {
        // Redirect to your lookup function
        lookupBarcode(decodedText); 
    });
};

// 3. Force the camera to start
function forceStartScanner() {
    const config = { fps: 10, qrbox: { width: 250, height: 150 } };
    
    html5QrCode.start(
        { facingMode: "user" }, // Forces Laptop Webcam
        config,
        qrCodeSuccessCallback
    ).then(() => {
        // UI Updates once camera is LIVE
        document.getElementById('camera-status').innerText = 'Live';
        document.getElementById('camera-status').className = 'badge badge-success';
        
        // Hide the "Requires mobile app" text
        const demoText = document.querySelector('p[style*="font-size: 12px"]');
        if(demoText) demoText.style.display = 'none';
        
    }).catch(err => {
        console.error("Camera Error: ", err);
        document.getElementById('interactive').innerHTML = 
            `<div style="color:white; text-align:center; padding:50px;">
                Camera Access Denied.<br>Please click the Lock icon in the URL bar and Allow Camera.
            </div>`;
    });
}

// 4. Run immediately when DOM is ready
if (document.readyState === "complete" || document.readyState === "interactive") {
    forceStartScanner();
} else {
    document.addEventListener("DOMContentLoaded", forceStartScanner);
}

  // Helper to handle the lookup
  function handleScanSuccess(barcode) {
      // Trigger your State 2: Loading UI
      document.getElementById('state-viewfinder').classList.remove('scan-state-active');
      document.getElementById('state-loading').classList.add('scan-state-active');

      // Fetch from your backend route
      fetch(`/scan/lookup?barcode=${barcode}`)
