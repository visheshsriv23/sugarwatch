<!-- State 1: Scanner -->
<div id="state-viewfinder" class="scan-state active">
  <div class="grid-2">
    <!-- Scanner UI -->
    <div>
      <div class="card mb-2">
        <div class="card-header">
          <span class="card-title">Barcode Scanner</span>
          <span id="camera-status" class="badge badge-info">Initializing...</span>
        </div>
        <div class="card-body">
         <div class="viewfinder" style="position: relative; overflow: hidden;">
    <div id="interactive" style="width: 100%; min-height: 250px;"></div>
    
    <div class="vf-corner vf-tl" style="z-index: 10; pointer-events: none;"></div>
    <div class="vf-corner vf-tr" style="z-index: 10; pointer-events: none;"></div>
    <div class="vf-corner vf-bl" style="z-index: 10; pointer-events: none;"></div>
    <div class="vf-corner vf-br" style="z-index: 10; pointer-events: none;"></div>
    <div class="scan-line" style="z-index: 11; pointer-events: none;"></div>
</div>
            <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;opacity:.12;">
              <svg width="90" height="65" viewBox="0 0 90 65" fill="none"><rect x="2" y="8" width="5" height="49" fill="#fff"/><rect x="11" y="8" width="3" height="49" fill="#fff"/><rect x="18" y="8" width="7" height="49" fill="#fff"/><rect x="29" y="8" width="3" height="49" fill="#fff"/><rect x="36" y="8" width="5" height="49" fill="#fff"/><rect x="45" y="8" width="3" height="49" fill="#fff"/><rect x="52" y="8" width="7" height="49" fill="#fff"/><rect x="63" y="8" width="3" height="49" fill="#fff"/><rect x="70" y="8" width="5" height="49" fill="#fff"/><rect x="79" y="8" width="3" height="49" fill="#fff"/><rect x="86" y="8" width="3" height="49" fill="#fff"/></svg>
            </div>
            <div style="position:absolute;bottom:14px;left:50%;transform:translateX(-50%);font-size:11px;color:rgba(255,255,255,.5);white-space:nowrap;">Align barcode within frame</div>
          </div>
          <p style="font-size:12px;color:var(--muted);text-align:center;margin-bottom:1rem;">Camera scanning requires the mobile app. Select a product below to demo.</p>
          <div style="display:flex;gap:8px;">
            <input class="form-control" type="text" id="manualBarcode" placeholder="Enter barcode manually..." style="flex:1;"/>
            <button class="btn btn-outline" onclick="lookupBarcode()">Lookup</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Manual Add Form -->
    <div>
      <div class="card">
        <div class="card-header">
          <span class="card-title">Add food manually</span>
        </div>
        <div class="card-body">
          <form action="/scan/log" method="POST">
            <div class="form-group">
              <label class="form-label">Product name *</label>
              <input class="form-control" type="text" name="productName" placeholder="e.g. Parle-G Biscuits" required/>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Brand</label>
                <input class="form-control" type="text" name="brand" placeholder="e.g. Parle"/>
              </div>
              <div class="form-group">
                <label class="form-label">Serving size</label>
                <input class="form-control" type="text" name="servingSize" placeholder="e.g. 100g"/>
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Sugar (grams) *</label>
                <input class="form-control" type="number" name="sugarG" min="0" max="500" step="0.1" placeholder="0.0" required/>
              </div>
              <div class="form-group">
                <label class="form-label">Calories (kcal)</label>
                <input class="form-control" type="number" name="calories" min="0" placeholder="0"/>
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Carbs (g)</label>
                <input class="form-control" type="number" name="carbs" min="0" step="0.1" placeholder="0.0"/>
              </div>
              <div class="form-group">
                <label class="form-label">Fat (g)</label>
                <input class="form-control" type="number" name="fat" min="0" step="0.1" placeholder="0.0"/>
              </div>
            </div>
            <div class="form-group">
              <label class="form-label">Meal type</label>
              <select class="form-control form-select" name="mealType">
                <option value="breakfast">🌅 Breakfast</option>
                <option value="lunch">🍱 Lunch</option>
                <option value="dinner">🌙 Dinner</option>
                <option value="snack" selected>🍿 Snack</option>
              </select>
            </div>
            <button type="submit" class="btn btn-primary w-full" style="justify-content:center;">
              Log this food
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- Sample Products -->
  <div class="card mt-2">
    <div class="card-header">
      <span class="card-title">Quick scan — popular Indian products</span>
      <span style="font-size:11px;color:var(--muted);">Click any product to demo scan</span>
    </div>
    <div class="card-body">
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:10px;">
        <% const samples = [
          { key:'parlg',   icon:'🍪', name:'Parle-G 100g',        brand:'Parle', sugar:28, cls:'danger' },
          { key:'frooti',  icon:'🥤', name:'Frooti Mango 200ml',  brand:'Parle Agro', sugar:22, cls:'danger' },
          { key:'maggi',   icon:'🍜', name:'Maggi Masala 70g',    brand:'Nestlé', sugar:3, cls:'ok' },
          { key:'kurkure', icon:'🌽', name:'Kurkure Masala 50g',  brand:'PepsiCo', sugar:2, cls:'ok' },
          { key:'goodday', icon:'🍘', name:'Good Day 75g',        brand:'Britannia', sugar:18, cls:'warn' },
