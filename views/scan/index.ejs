    <div class="container mt-4">
    <h2 class="text-center mb-4">Scan Product Barcode</h2>
    
    <div id="reader" style="width: 100%; max-width: 500px; margin: auto; border-radius: 15px; overflow: hidden; border: 2px solid var(--amber);"></div>
    
    <div id="scan-status" class="text-center mt-3">
        <p class="text-muted">Align the barcode within the frame</p>
    </div>

    <div class="mt-4 text-center">
        <p>Can't scan? Enter manually:</p>
        <form action="/products/search-barcode" method="POST" class="d-flex justify-content-center">
            <input type="text" name="barcode" class="form-control w-50" placeholder="Enter 13-digit code">
            <button type="submit" class="btn btn-primary ms-2">Go</button>
        </form>
    </div>
</div>

    <!-- Manual Add Form -->
    <div>
      <div class="card">
        <div class="card-header">
          <span class="card-title">Add food manually</span>
        </div>
        <div class="card-body">
          <form action="/scan/log" method="POST">
            <div class="form-group">
              <label class="form-label">Product name *</label>
              <input class="form-control" type="text" name="productName" placeholder="e.g. Parle-G Biscuits" required/>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Brand</label>
                <input class="form-control" type="text" name="brand" placeholder="e.g. Parle"/>
              </div>
              <div class="form-group">
                <label class="form-label">Serving size</label>
                <input class="form-control" type="text" name="servingSize" placeholder="e.g. 100g"/>
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Sugar (grams) *</label>
                <input class="form-control" type="number" name="sugarG" min="0" max="500" step="0.1" placeholder="0.0" required/>
              </div>
              <div class="form-group">
                <label class="form-label">Calories (kcal)</label>
                <input class="form-control" type="number" name="calories" min="0" placeholder="0"/>
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Carbs (g)</label>
                <input class="form-control" type="number" name="carbs" min="0" step="0.1" placeholder="0.0"/>
              </div>
              <div class="form-group">
                <label class="form-label">Fat (g)</label>
                <input class="form-control" type="number" name="fat" min="0" step="0.1" placeholder="0.0"/>
              </div>
            </div>
            <div class="form-group">
              <label class="form-label">Meal type</label>
              <select class="form-control form-select" name="mealType">
                <option value="breakfast">🌅 Breakfast</option>
                <option value="lunch">🍱 Lunch</option>
                <option value="dinner">🌙 Dinner</option>
                <option value="snack" selected>🍿 Snack</option>
              </select>
            </div>
            <button type="submit" class="btn btn-primary w-full" style="justify-content:center;">
              Log this food
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- Sample Products -->
  <div class="card mt-2">
    <div class="card-header">
      <span class="card-title">Quick scan — popular Indian products</span>
      <span style="font-size:11px;color:var(--muted);">Click any product to demo scan</span>
    </div>
    <div class="card-body">
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:10px;">
        <% const samples = [
          { key:'parlg',   icon:'🍪', name:'Parle-G 100g',        brand:'Parle', sugar:28, cls:'danger' },
          { key:'frooti',  icon:'🥤', name:'Frooti Mango 200ml',  brand:'Parle Agro', sugar:22, cls:'danger' },
          { key:'maggi',   icon:'🍜', name:'Maggi Masala 70g',    brand:'Nestlé', sugar:3, cls:'ok' },
          { key:'kurkure', icon:'🌽', name:'Kurkure Masala 50g',  brand:'PepsiCo', sugar:2, cls:'ok' },
          { key:'goodday', icon:'🍘', name:'Good Day 75g',        brand:'Britannia', sugar:18, cls:'warn' },
          { key:'amul',    icon:'☕', name:'Amul Kool Café 200ml',brand:'Amul', sugar:20, cls:'danger' }
        ] %>
        <% samples.forEach(s => { %>
        <div onclick="startDemoScan('<%= s.key %>')" style="background:var(--bg);border:1.5px solid var(--border);border-radius:var(--radius);padding:12px;cursor:pointer;transition:all .18s;display:flex;gap:10px;align-items:center;" onmouseover="this.style.borderColor='var(--orange)'" onmouseout="this.style.borderColor='var(--border)'">
          <div style="font-size:22px;flex-shrink:0;"><%= s.icon %></div>
          <div>
            <div style="font-size:12px;font-weight:600;"><%= s.name %></div>
            <div style="font-size:10px;color:var(--muted);"><%= s.brand %></div>
            <span class="badge badge-<%= s.cls %>" style="margin-top:4px;"><%= s.sugar %>g sugar</span>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
  </div>
</div>

<!-- State 2: Loading -->
<div id="state-loading" class="scan-state">
  <div class="card" style="max-width:480px;margin:2rem auto;">
    <div class="card-body" style="text-align:center;padding:2.5rem;">
      <div class="spinner"></div>
      <div style="font-family:var(--syne);font-size:1rem;font-weight:700;margin-bottom:.25rem;" id="loading-name">Scanning...</div>
      <div style="font-size:12px;color:var(--muted);margin-bottom:1.5rem;">Checking Indian food database</div>
      <div style="text-align:left;">
        <div class="lstep" id="lstep-1"><div class="lstep-dot">1</div> Reading barcode</div>
        <div class="lstep" id="lstep-2"><div class="lstep-dot">2</div> Matching product in database</div>
        <div class="lstep" id="lstep-3"><div class="lstep-dot">3</div> Calculating sugar in teaspoons</div>
        <div class="lstep" id="lstep-4"><div class="lstep-dot">4</div> Detecting hidden sugar aliases</div>
        <div class="lstep" id="lstep-5"><div class="lstep-dot">5</div> Generating health rating</div>
      </div>
    </div>
  </div>
</div>

<!-- State 3: Result -->
<div id="state-result" class="scan-state">
  <div style="max-width:560px;margin:0 auto;">
    <div class="card mb-2">
      <div style="padding:1.25rem 1.25rem 1rem;border-bottom:1px solid var(--border);">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
          <span id="r-brand" style="background:var(--bg2);border-radius:6px;padding:3px 8px;font-size:10px;color:var(--muted);"></span>
          <span id="r-barcode" style="font-size:10px;color:var(--hint);"></span>
        </div>
        <div id="r-name" style="font-family:var(--syne);font-size:1rem;font-weight:700;"></div>
        <div id="r-serving" style="font-size:11px;color:var(--muted);margin-top:2px;"></div>
      </div>
      <div class="card-body">
        <div style="text-align:center;margin-bottom:1.25rem;">
          <div id="r-sugar-g" style="font-family:var(--syne);font-size:3rem;font-weight:800;line-height:1;"></div>
          <div style="font-size:13px;color:var(--muted);margin-top:4px;">of sugar per serving</div>
          <div id="r-tsp" style="font-family:var(--syne);font-size:1.1rem;font-weight:700;margin-top:6px;"></div>
          <div id="r-tsp-icons" style="display:flex;gap:5px;justify-content:center;flex-wrap:wrap;margin:10px 0;"></div>
        </div>

        <div style="margin-bottom:1rem;">
          <div style="display:flex;justify-content:space-between;font-size:12px;color:var(--muted);margin-bottom:6px;">
            <span>% of daily limit (25g)</span>
            <span id="r-pct-label" style="font-weight:600;"></span>
          </div>
          <div class="sugar-track"><div id="r-meter" class="sugar-fill" style="width:0;"></div></div>
        </div>

        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin:1rem 0;">
          <div style="background:var(--bg);border-radius:8px;padding:10px;text-align:center;">
            <div id="r-cal" style="font-family:var(--syne);font-size:.95rem;font-weight:700;"></div>
            <div style="font-size:10px;color:var(--muted);margin-top:2px;">Calories</div>
          </div>
          <div style="background:var(--bg);border-radius:8px;padding:10px;text-align:center;">
            <div id="r-carbs" style="font-family:var(--syne);font-size:.95rem;font-weight:700;"></div>
            <div style="font-size:10px;color:var(--muted);margin-top:2px;">Carbs</div>
          </div>
          <div style="background:var(--bg);border-radius:8px;padding:10px;text-align:center;">
            <div id="r-fat" style="font-family:var(--syne);font-size:.95rem;font-weight:700;"></div>
            <div style="font-size:10px;color:var(--muted);margin-top:2px;">Fat</div>
          </div>
        </div>

        <div id="r-alert" style="border-radius:var(--radius);padding:14px;display:flex;gap:10px;align-items:flex-start;margin-bottom:1rem;">
          <div id="r-alert-icon" style="width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;color:#fff;flex-shrink:0;margin-top:1px;">!</div>
          <div>
            <div id="r-alert-title" style="font-size:13px;font-weight:600;margin-bottom:3px;"></div>
            <div id="r-alert-body" style="font-size:12px;opacity:.85;line-height:1.5;"></div>
          </div>
        </div>

        <!-- Log form hidden -->
        <form action="/scan/log" method="POST" id="logForm">
          <input type="hidden" name="productName" id="f-name"/>
          <input type="hidden" name="brand" id="f-brand"/>
          <input type="hidden" name="sugarG" id="f-sugar"/>
          <input type="hidden" name="calories" id="f-cal"/>
          <input type="hidden" name="carbs" id="f-carbs"/>
          <input type="hidden" name="fat" id="f-fat"/>
          <input type="hidden" name="servingSize" id="f-serving"/>
          <input type="hidden" name="barcode" id="f-barcode"/>
          <div class="form-group">
            <label class="form-label">Meal type</label>
            <select class="form-control form-select" name="mealType">
              <option value="breakfast">🌅 Breakfast</option>
              <option value="lunch">🍱 Lunch</option>
              <option value="dinner">🌙 Dinner</option>
              <option value="snack" selected>🍿 Snack</option>
            </select>
          </div>
          <div style="display:flex;gap:8px;">
            <button type="button" class="btn btn-outline" onclick="resetScan()" style="flex:1;justify-content:center;">← Scan again</button>
            <button type="submit" class="btn btn-primary" style="flex:2;justify-content:center;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20,6 9,17 4,12"/></svg>
              Add to food log
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script src="https://unpkg.com/html5-qrcode"></script>

<script>
    const statusText = document.getElementById('scan-status');

    function onScanSuccess(decodedText, decodedResult) {
        // Stop scanning immediately to prevent multiple triggers
        html5QrcodeScanner.clear();
        
        statusText.innerHTML = `<div class="spinner-border text-warning" role="status"></div><p>Product Found! Fetching data...</p>`;
        
        // Step 2: Redirect to your backend route with the barcode
        window.location.href = `/products/barcode/${decodedText}`;
    }

    function onScanFailure(error) {
        // Frame-by-frame errors are ignored to keep the console clean
    }

    let html5QrcodeScanner = new Html5QrcodeScanner(
        "reader", 
        { 
            fps: 15, 
            qrbox: { width: 280, height: 160 },
            aspectRatio: 1.0 
        }, 
        false
    );
    
    html5QrcodeScanner.render(onScanSuccess, onScanFailure);
</script>
