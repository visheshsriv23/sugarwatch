# ─────────────────────────────────────────
#  SugarWatch — Environment Variables
#  Copy this file to .env and fill values
# ─────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3000

# MongoDB
MONGO_URI=your_mongodb_connection_string_here 
# For MongoDB Atlas:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/sugarwatch?retryWrites=true&w=majority

# Session
SESSION_SECRET=your_super_secret_session_key_change_this_in_production_min_32_chars

# App
APP_NAME=SugarWatch
APP_URL=http://localhost:3000
